-- Questão 1

SELECT DISTINCT c.*
FROM clientes c
WHERE c.id IN (
    SELECT v.cliente_id
    FROM vendas v
    INNER JOIN itens_venda iv ON iv.venda_id = v.id
    INNER JOIN produtos p ON p.id = iv.produto_id
    WHERE p.descricao LIKE '%ração%'
);

-- Questão 2

WITH total_por_venda AS (
    SELECT 
        v.id AS venda_id,
        v.cliente_id,
        SUM(iv.quantidade * iv.preco_unitario) AS total_venda
    FROM vendas v
    INNER JOIN itens_venda iv ON iv.venda_id = v.id
    GROUP BY v.id, v.cliente_id
),
media_por_cliente AS (
    SELECT 
        c.id,
        c.nome,
        AVG(tp.total_venda) AS media_compra
    FROM clientes c
    INNER JOIN total_por_venda tp ON tp.cliente_id = c.id
    GROUP BY c.id, c.nome
)
SELECT *
FROM media_por_cliente
WHERE media_compra > 200;

-- Questão 3

SELECT p.*
FROM produtos p
WHERE p.id IN (
    SELECT iv.produto_id
    FROM itens_venda iv
    GROUP BY iv.produto_id
    HAVING SUM(iv.quantidade) > 2
);
-- Questão 4

WITH total_agendamentos AS (
    SELECT 
        servico_id,
        COUNT(*) AS total
    FROM agendamentos
    GROUP BY servico_id
)
SELECT 
    s.nome,
    ta.total
FROM total_agendamentos ta
INNER JOIN servicos s ON s.id = ta.servico_id
ORDER BY ta.total DESC
LIMIT 3;

-- Questão 5a

WITH gastos_cliente AS (
    SELECT 
        c.id,
        c.nome,
        SUM(iv.quantidade * iv.preco_unitario) AS total_gasto
    FROM clientes c
    INNER JOIN vendas v ON v.cliente_id = c.id
    INNER JOIN itens_venda iv ON iv.venda_id = v.id
    GROUP BY c.id, c.nome
)
SELECT *
FROM gastos_cliente;

-- Questão 5b

WITH gastos_cliente AS (
    SELECT 
        c.id,
        SUM(iv.quantidade * iv.preco_unitario) AS total_gasto
    FROM clientes c
    INNER JOIN vendas v ON v.cliente_id = c.id
    INNER JOIN itens_venda iv ON iv.venda_id = v.id
    GROUP BY c.id
)
SELECT AVG(total_gasto) AS media_geral
FROM gastos_cliente;

-- Questão 5c

WITH gastos_cliente AS (
    SELECT 
        c.id,
        c.nome,
        SUM(iv.quantidade * iv.preco_unitario) AS total_gasto
    FROM clientes c
    INNER JOIN vendas v ON v.cliente_id = c.id
    INNER JOIN itens_venda iv ON iv.venda_id = v.id
    GROUP BY c.id, c.nome
),
pets_cliente AS (
    SELECT 
        cliente_id,
        COUNT(*) AS qtd_pets
    FROM pets
    GROUP BY cliente_id
)
SELECT 
    g.nome,
    g.total_gasto
FROM gastos_cliente g
INNER JOIN pets_cliente p ON p.cliente_id = g.id
WHERE g.total_gasto > (
    SELECT AVG(total_gasto)
    FROM gastos_cliente
)
AND p.qtd_pets > 1;
